# apps/ai reads the SINGLE root .env locally (CLAUDE.md: no per-app .env files).
# On Railway, set these as service variables in the dashboard instead.
# This file only documents the keys the service uses.

# Postgres (same DB as the rest of the monorepo). apps/ai now READS AND WRITES it
# (chat tool execution: transactions, debts, wallets, audit, quota).
DATABASE_URL=postgresql://user:pass@localhost:5432/oewang

# LLM / embeddings — OpenAI covers both chat and embeddings
OPENAI_API_KEY=             # chat + embeddings (text-embedding-3-small, 1536-dim)
AI_CHAT_MODEL=gpt-4o-mini
AI_EMBED_MODEL=text-embedding-3-small

# Service-to-service auth: shared secret used BOTH ways — apps/api → sidecar
# (`x-api-key`) and the sidecar → Elysia /ai/internal/* (chat-begin/end/system-prompt).
# Empty = auth OFF (dev only). REQUIRED in production.
AI_SERVICE_API_KEY=

# Elysia base URL the sidecar calls back to for the website chat's identity/session/
# quota plumbing. On Railway use the internal URL (e.g. http://api.railway.internal:3002).
API_INTERNAL_URL=http://localhost:3002

# Max tool-calling steps for the chat loop.
AI_MAX_STEPS=10

# Port. Railway injects $PORT at runtime (the Dockerfile/start command honor it);
# AI_PORT is only the local default.
AI_PORT=3004

# Money-path flags (mirror apps/api API_CONFIG):
#   RECEIPT_DRY_RUN=true  -> create_transaction/add_items return a preview, NOTHING persists
#   MOCK_AI_QUOTA=true    -> skip the token-limit (422 PLAN_LIMIT_REACHED) check
# Defaults: RECEIPT_DRY_RUN=false (writes persist), MOCK_AI_QUOTA=true.
RECEIPT_DRY_RUN=false
MOCK_AI_QUOTA=true

# Anomaly background scan. 0 disables it; >0 = run every N hours.
ANOMALY_SCAN_HOURS=0
# Where the scan POSTs alerts (an Elysia endpoint that forwards to WhatsApp/Telegram).
ALERT_CALLBACK_URL=

# NOTE: the consumers (apps/api, apps/app) must set AI_SERVICE_URL to THIS service's
# URL so they route AI traffic here (e.g. http://ai.railway.internal:$PORT). Without
# it, AI features are unavailable — there is no in-process fallback anymore.
