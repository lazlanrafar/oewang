{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "bun run --watch index.ts",
    "build": "bun build index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "billing:worker": "bun run scripts/billing-worker.ts",
    "storage:worker": "bun run scripts/storage-worker.ts",
    "lint": "biome lint",
    "test": "bun test",
    "test:integration": "NODE_ENV=test bun test --preload ./test/setup.ts ./test/integration/**/*.test.ts",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@elysiajs/cors": "^1.3.1",
    "@elysiajs/static": "^1.4.7",
    "@elysiajs/swagger": "^1.3.0",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sentry/bun": "^10.18.0",
    "@workspace/bucket": "workspace:*",
    "@workspace/currencyfreaks": "workspace:*",
    "@workspace/database": "workspace:*",
    "@workspace/email": "workspace:*",
    "@workspace/encryption": "workspace:*",
    "@workspace/logger": "workspace:*",
    "@workspace/redis": "workspace:*",
    "@workspace/types": "workspace:*",
    "@workspace/utils": "workspace:*",
    "date-fns": "catalog:",
    "drizzle-orm": "catalog:",
    "elysia": "^1.3.3",
    "jose": "^6.0.11",
    "openai": "^6.27.0",
    "pdf.js-extract": "^0.2.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "web-push": "^3.6.7",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "^1.2.21",
    "@types/web-push": "^3.6.4",
    "@workspace/typescript-config": "workspace:*",
    "typescript": "catalog:"
  }
}
