# Copy to `.env` and fill in values before running. The .env file is bundled
# as a Flutter asset (see pubspec.yaml).

# Base URL of the Elysia API. `/v1` is appended by ApiClient.
API_URL=http://localhost:3002

# TRANSPORT key only — must match `ENCRYPTION_KEY` in the monorepo .env so the
# AES-256-GCM API round-trip works. This key IS bundled into the app binary, so
# it must never be used for at-rest secrets server-side (that's DATA_ENCRYPTION_KEY,
# which is server-only and never shipped here). TLS is the real transport control.
ENCRYPTION_KEY=

# JWT cookie / storage key. Match the web app default.
SESSION_COOKIE_NAME=oewang-session
