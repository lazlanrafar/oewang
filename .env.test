# Test Environment Configuration
# This file is used for running tests and should mirror .env structure

# Node Environment
NODE_ENV=test

# Database (Test database - isolated from dev/prod)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/oewang_test

# Redis (Use different DB index for tests)
REDIS_URL=redis://localhost:6379/1

# Supabase (Test project or use existing with test data)
SUPABASE_URL=${SUPABASE_URL}
SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}
SUPABASE_SERVICE_ROLE_KEY=${SUPABASE_SERVICE_ROLE_KEY}

# API Configuration
API_PORT=3002
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth
JWT_SECRET=test-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=test-encryption-key-32-characters

# Logging
LOG_LEVEL=error
LOG_PRETTY=false

# Test-specific flags
TEST_MODE=true
SKIP_AUTH_CHECKS=false

# External Services (Use test/sandbox modes)
STRIPE_SECRET_KEY=${STRIPE_SECRET_KEY}
STRIPE_WEBHOOK_SECRET=${STRIPE_WEBHOOK_SECRET}

# Disable analytics/tracking in tests
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Web Push (Use test keys)
VAPID_PUBLIC_KEY=${VAPID_PUBLIC_KEY}
VAPID_PRIVATE_KEY=${VAPID_PRIVATE_KEY}
VAPID_SUBJECT=${VAPID_SUBJECT}
NEXT_PUBLIC_VAPID_PUBLIC_KEY=${NEXT_PUBLIC_VAPID_PUBLIC_KEY}
