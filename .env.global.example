# ==========================================
# oewang GLOBAL — Railway Shared Variables (Example)
# Copy this file to .env.global and fill in real values.
# Then copy all variables into Railway → Shared Variables.
# These are referenced as ${{shared.VARIABLE_NAME}} in per-service env files.
# ==========================================

# ── Application ───────────────────────────
API_PORT="3002"
NODE_ENV="production"

# ── Auth & Security ───────────────────────
JWT_SECRET=                                # min 32 chars, e.g: openssl rand -hex 32
JWT_EXPIRES_IN="7d"
ENCRYPTION_KEY=                            # exactly 32 chars, e.g: openssl rand -hex 16

# ── Payment (Mayar) ───────────────────────
MAYAR_API_URL="https://api.mayar.id/hl/v1"
MAYAR_API_KEY=                             # From Mayar dashboard → Developer → API Key
MAYAR_WEBHOOK_TOKEN=                       # From Mayar dashboard → Developer → Webhook

# ── AI ────────────────────────────────────
OPENAI_API_KEY=                            # From platform.openai.com/api-keys
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Web Push (VAPID) ──────────────────────
VAPID_PUBLIC_KEY=                          # Generate: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=                             # e.g: mailto:admin@yourdomain.com

# ── Email ─────────────────────────────────
RESEND_API_KEY=                            # From resend.com → API Keys

# ── Currency ──────────────────────────────
CURRENCYFREAKS_API_KEY=                    # From currencyfreaks.com

# ── Telegram ──────────────────────────────
TELEGRAM_BOT_TOKEN=                        # From @BotFather on Telegram
TELEGRAM_WEBHOOK_SECRET=                   # Generate: openssl rand -hex 32

# ── Evolution API (WhatsApp) ──────────────
EVOLUTION_API_URL=                         # e.g: https://evolutionapi.yourdomain.com
EVOLUTION_API_TOKEN=                       # From Evolution API dashboard
EVOLUTION_API_INSTANCE=                    # Instance name from Evolution API dashboard

# ── OAuth ─────────────────────────────────
GOOGLE_CLIENT_ID=                          # From Google Cloud Console → Credentials
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=                          # From GitHub → Settings → Developer settings → OAuth Apps
GITHUB_CLIENT_SECRET=

# ── Logging ───────────────────────────────
LOG_LEVEL="info"                           # trace | debug | info | warn | error | fatal
LOG_PRETTY="false"                         # true in dev, false in production

# ── Public Config (shared across Next.js frontends) ───────────────
NEXT_PUBLIC_SESSION_COOKIE_NAME="oewang-session"
NEXT_PUBLIC_TELEGRAM_BOT_USER=             # Your bot's username without @
NEXT_PUBLIC_WHATSAPP_NUMBER=               # Plain number e.g. 628xxxxxxxxx
NEXT_PUBLIC_VAPID_PUBLIC_KEY=              # Same value as VAPID_PUBLIC_KEY above
