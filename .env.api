# ==========================================
# oewang API — Railway Environment Variables
# Copy this into Railway → api service → Variables
# ==========================================

# ── Application ───────────────────────────
NODE_ENV="${{shared.NODE_ENV}}"
API_PORT="${{shared.API_PORT}}"
API_BASE_URL="https://${{RAILWAY_PUBLIC_DOMAIN}}"
NEXT_PUBLIC_API_URL="https://${{RAILWAY_PUBLIC_DOMAIN}}"
NEXT_PUBLIC_APP_URL="https://${{app.RAILWAY_PUBLIC_DOMAIN}}"

# ── Database ──────────────────────────────
DATABASE_URL="${{postgres.DATABASE_URL}}"

# ── Auth & Security ───────────────────────
JWT_SECRET="${{shared.JWT_SECRET}}"
JWT_EXPIRES_IN="${{shared.JWT_EXPIRES_IN}}"
ENCRYPTION_KEY="${{shared.ENCRYPTION_KEY}}"

# ── Redis ─────────────────────────────────
# Use one of the two options below:
REDIS_URL="${{redis.REDIS_URL}}"
# UPSTASH_REDIS_REST_URL="${{shared.UPSTASH_REDIS_REST_URL}}"
# UPSTASH_REDIS_REST_TOKEN="${{shared.UPSTASH_REDIS_REST_TOKEN}}"

# ── Payment (Mayar) ───────────────────────
MAYAR_API_URL="${{shared.MAYAR_API_URL}}"
MAYAR_API_KEY="${{shared.MAYAR_API_KEY}}"
MAYAR_WEBHOOK_TOKEN="${{shared.MAYAR_WEBHOOK_TOKEN}}"

# ── AI ────────────────────────────────────
OPENAI_API_KEY="${{shared.OPENAI_API_KEY}}"
# GEMINI_API_KEY="${{shared.GEMINI_API_KEY}}"
# ANTHROPIC_API_KEY="${{shared.ANTHROPIC_API_KEY}}"

# ── Web Push (VAPID) ──────────────────────
VAPID_PUBLIC_KEY="${{shared.VAPID_PUBLIC_KEY}}"
VAPID_PRIVATE_KEY="${{shared.VAPID_PRIVATE_KEY}}"
VAPID_SUBJECT="${{shared.VAPID_SUBJECT}}"

# ── Email ─────────────────────────────────
RESEND_API_KEY="${{shared.RESEND_API_KEY}}"

# ── Currency ──────────────────────────────
CURRENCYFREAKS_API_KEY="${{shared.CURRENCYFREAKS_API_KEY}}"

# ── Telegram ──────────────────────────────
TELEGRAM_BOT_TOKEN="${{shared.TELEGRAM_BOT_TOKEN}}"
TELEGRAM_WEBHOOK_SECRET="${{shared.TELEGRAM_WEBHOOK_SECRET}}"

# ── Google OAuth (Login + Gmail integration fallback) ──
GOOGLE_CLIENT_ID="${{shared.GOOGLE_CLIENT_ID}}"
GOOGLE_CLIENT_SECRET="${{shared.GOOGLE_CLIENT_SECRET}}"

# ── Gmail Integration (optional — falls back to GOOGLE_CLIENT_ID) ──
# GOOGLE_GMAIL_CLIENT_ID="${{shared.GOOGLE_GMAIL_CLIENT_ID}}"
# GOOGLE_GMAIL_CLIENT_SECRET="${{shared.GOOGLE_GMAIL_CLIENT_SECRET}}"

# ── Outlook / Microsoft OAuth (optional) ──────────────
# MICROSOFT_CLIENT_ID="${{shared.MICROSOFT_CLIENT_ID}}"
# MICROSOFT_CLIENT_SECRET="${{shared.MICROSOFT_CLIENT_SECRET}}"

# ── Evolution API (WhatsApp) ──────────────
EVOLUTION_API_URL="${{shared.EVOLUTION_API_URL}}"
EVOLUTION_API_TOKEN="${{shared.EVOLUTION_API_TOKEN}}"
EVOLUTION_API_INSTANCE="${{shared.EVOLUTION_API_INSTANCE}}"

# ── S3 / Object Storage ───────────────────
BUCKET_ENDPOINT="${{bucket.ENDPOINT}}"
BUCKET_REGION="${{bucket.REGION}}"
BUCKET_ACCESS_KEY_ID="${{bucket.ACCESS_KEY_ID}}"
BUCKET_SECRET_ACCESS_KEY="${{bucket.SECRET_ACCESS_KEY}}"
BUCKET_NAME="${{bucket.BUCKET}}"

# ── Monitoring ────────────────────────────
# SENTRY_DSN="${{shared.SENTRY_DSN}}"

# ── Logging ───────────────────────────────
LOG_LEVEL="${{shared.LOG_LEVEL}}"
LOG_PRETTY="${{shared.LOG_PRETTY}}"
