{
  "name": "oewang",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "turbo run typecheck",
    "migrate": "turbo run migrate",
    "db:push": "bun run --cwd packages/database push",
    "db:migrate": "bun run --cwd packages/database migrate",
    "db:seed": "bun run --cwd packages/database seed",
    "db:reset": "bun run --cwd packages/database reset && bun run db:push && bun run db:seed",
    "db:migrate:prod": "bun run --cwd packages/database prod:migrate",
    "db:seed:prod": "bun run --cwd packages/database prod:seed",
    "db:release:prod": "bun run db:migrate:prod && bun run db:seed:prod",
    "mcp": "bun run --cwd apps/api mcp.ts",
    "test": "bash -c 'cd apps/api && bun test modules/'",
    "test:e2e": "turbo run test:e2e",
    "test:e2e:ui": "cd apps/app && bun run test:e2e:ui",
    "test:watch": "bash -c 'cd apps/api && bun test --watch modules/'",
    "test:coverage": "bash -c 'cd apps/api && bun test --coverage modules/'"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "catalog:",
    "@faker-js/faker": "^10.4.0",
    "pixelmatch": "^7.2.0",
    "prettier": "catalog:",
    "tinybench": "^6.0.2",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "catalog": {
    "typescript": "5.9.2",
    "@biomejs/biome": "2.3.14",
    "prettier": "3.7.4",
    "turbo": "2.8.5",
    "zod": "3.25.76",
    "date-fns": "4.1.0",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "lucide-react": "0.575.0",
    "clsx": "2.1.1",
    "tailwind-merge": "3.4.0",
    "sonner": "2.0.7",
    "radix-ui": "1.4.3",
    "drizzle-orm": "0.45.1",
    "nuqs": "2.8.9"
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
