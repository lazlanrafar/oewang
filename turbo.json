{
  "$schema": "https://turborepo.dev/schema.json",
  // "ui": "tui",
  "globalEnv": [
    "API_PORT",
    "SENTRY_DSN",
    "SENTRY_AUTH_TOKEN",
    "NEXT_PUBLIC_SENTRY_DSN",
    "LOG_LEVEL",
    "LOG_PRETTY",
    "DATABASE_URL",
    "ENCRYPTION_KEY",
    "JWT_SECRET",
    "JWT_EXPIRES_IN",
    "REDIS_URL",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_APP_URL",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "NEXT_PUBLIC_VAPID_PUBLIC_KEY",
    "VAPID_PUBLIC_KEY",
    "VAPID_PRIVATE_KEY",
    "VAPID_SUBJECT",
    "AI_SERVICE_URL",
    "AI_SERVICE_API_KEY"
  ],
  "globalPassThroughEnv": ["NODE_ENV", "PLAYWRIGHT_*"],
  "tasks": {
    "test:e2e": {
      "dependsOn": ["^build"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "migrate": {
      "cache": false
    }
  }
}
