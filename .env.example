# ==========================================
# oewang - Environment Variables Example
# Copy this file to .env and fill in values
# ==========================================
NODE_ENV=development

# API config
API_PORT=3002
API_BASE_URL=https://your-api-domain.com

# Workspace URLs
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
WEBSITE_URL=http://localhost:3003

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/dbname"
DATABASE_POOL_MAX=2

# Redis — use one of the two options below
REDIS_URL=redis://localhost:6379
# UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Auth & Security
# JWT_SECRET must be at least 32 characters
JWT_SECRET=your-jwt-secret-minimum-32-characters-long
JWT_EXPIRES_IN=7d
# ENCRYPTION_KEY must be exactly 32 characters
ENCRYPTION_KEY=your-32-char-encryption-key-here

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Mayar (Payment Gateway — https://mayar.id)
MAYAR_API_URL="https://api.mayar.club/hl/v1"
MAYAR_API_KEY=your-mayar-api-key
MAYAR_WEBHOOK_TOKEN=your-mayar-webhook-token

# AI Providers — set at least one
OPENAI_API_KEY=sk-proj-...
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_...

# Currency exchange rates (CurrencyFreaks — https://currencyfreaks.com)
CURRENCYFREAKS_API_KEY=your-currencyfreaks-api-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Optional: shared secret for webhook verification
TELEGRAM_WEBHOOK_SECRET=

# Evolution API (WhatsApp — self-hosted)
EVOLUTION_API_URL=https://your-evolution-api-domain.com
EVOLUTION_API_TOKEN=your-evolution-api-token
# Instance name or UUID from the Evolution API dashboard
EVOLUTION_API_INSTANCE=your-instance-id

# S3-compatible Storage
# Local: use MinIO via docker-compose (docker compose up -d)
BUCKET_ENDPOINT=http://localhost:9000
BUCKET_REGION=us-east-1
BUCKET_ACCESS_KEY_ID=minioadmin
BUCKET_SECRET_ACCESS_KEY=minioadmin
BUCKET_NAME=okane
# Production: point to R2, S3, or any S3-compatible provider
# BUCKET_ENDPOINT=https://your-account.r2.cloudflarestorage.com
# BUCKET_ACCESS_KEY_ID=your-access-key
# BUCKET_SECRET_ACCESS_KEY=your-secret-key
# BUCKET_NAME=your-bucket-name

# Web Push Notifications (VAPID)
# Generate keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@yourdomain.com

# NEXT_PUBLIC — available in the browser bundle
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3003
NEXT_PUBLIC_SESSION_COOKIE_NAME=oewang-session
# WhatsApp number connected to your Evolution API instance (e.g. +628123456789)
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_TELEGRAM_BOT_USER=YourTelegramBotUsername
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# Monitoring (optional)
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_AUTH_TOKEN=
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# Testing (Playwright E2E)
PLAYWRIGHT_USER="test@example.com"
PLAYWRIGHT_PASS="YourTestPassword"
